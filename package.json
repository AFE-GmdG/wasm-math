{
  "name": "@afegmdg/wasm-math",
  "version": "0.1.5-beta",
  "description": "WebAssembly Math Library",
  "type": "module",
  "module": "./dist/wasm-math.js",
  "types": "./dist/wasm-math.d.ts",
  "license": "MIT",
  "author": {
    "name": "Andreas Friedel",
    "email": "opensource@afe-gmdg.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AFE-GmdG/wasm-math.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "rollup -c",
    "buildwasm": "wat2wasm src/wat/math.wat -o src/wasm/math.wasm",
    "pretest": "yarn build",
    "test": "vitest --run",
    "lint": "eslint src test",
    "rr": "rimraf dist node_modules yarn.lock"
  },
  "dependencies": {},
  "devDependencies": {
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-wasm": "6.2.2",
    "@stylistic/eslint-plugin-ts": "4.2.0",
    "@types/node": "22.14.1",
    "@typescript-eslint/eslint-plugin": "8.29.1",
    "@typescript-eslint/parser": "8.29.1",
    "eslint": "9.24.0",
    "eslint-plugin-import": "2.31.0",
    "rimraf": "6.0.1",
    "rollup": "4.39.0",
    "rollup-plugin-typescript2": "0.36.0",
    "typescript": "5.8.3",
    "vite": "6.2.6",
    "vitest": "3.1.1"
  }
}
